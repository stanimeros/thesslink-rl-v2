--- /dev/null
+++ b/src/modules/agents/dual_rnn_agent.py
@@ -0,0 +1,21 @@
+# Dual RNN stacks: separate parameters for negotiation (branch 0) vs navigation (branch 1).
+
+import torch as th
+import torch.nn as nn
+
+from .rnn_agent import RNNAgent
+
+
+class DualRNNAgent(nn.Module):
+    """Two RNNAgent modules; the runner selects which to use via ``policy_branch``."""
+
+    def __init__(self, input_shape, args):
+        super().__init__()
+        self.args = args
+        self.neg_agent = RNNAgent(input_shape, args)
+        self.nav_agent = RNNAgent(input_shape, args)
+
+    def init_hidden(self):
+        h0 = self.neg_agent.init_hidden()
+        h1 = self.nav_agent.init_hidden()
+        return th.stack([h0, h1], dim=0)
