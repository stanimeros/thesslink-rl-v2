+++ b/src/controllers/dual_basic_controller.py
@@ -0,0 +1,44 @@
+import torch as th
+import torch.nn.functional as F
+
+from .basic_controller import BasicMAC
+
+
+class DualBasicMAC(BasicMAC):
+    """BasicMAC with two agent stacks; ``policy_branch`` selects negotiate vs navigate."""
+
+    def forward(self, ep_batch, t, test_mode=False):
+        agent_inputs = self._build_inputs(ep_batch, t)
+        bs = ep_batch.batch_size
+        branch = ep_batch["policy_branch"][:, t].squeeze(-1).long()
+        br_flat = branch.repeat_interleave(self.n_agents)
+
+        h_neg = self.hidden_states[0].reshape(bs * self.n_agents, -1)
+        h_nav = self.hidden_states[1].reshape(bs * self.n_agents, -1)
+
+        q_neg, h_neg_out = self.agent.neg_agent(agent_inputs, h_neg)
+        q_nav, h_nav_out = self.agent.nav_agent(agent_inputs, h_nav)
+
+        br_exp = br_flat.unsqueeze(-1).float()
+        agent_outs = q_neg * (1 - br_exp) + q_nav * br_exp
+        h_neg_new = h_neg_out * (1 - br_exp) + h_neg * br_exp
+        h_nav_new = h_nav_out * br_exp + h_nav * (1 - br_exp)
+
+        self.hidden_states = th.stack([h_neg_new, h_nav_new], dim=0).view(
+            2, bs, self.n_agents, -1
+        )
+
+        if self.agent_output_type == "pi_logits":
+            avail_actions = ep_batch["avail_actions"][:, t]
+            if getattr(self.args, "mask_before_softmax", True):
+                reshaped = avail_actions.reshape(bs * self.n_agents, -1)
+                agent_outs[reshaped == 0] = -1e10
+            agent_outs = F.softmax(agent_outs, dim=-1)
+
+        return agent_outs.view(bs, self.n_agents, -1)
+
+    def init_hidden(self, batch_size):
+        h = self.agent.init_hidden()
+        self.hidden_states = (
+            h.unsqueeze(1).expand(2, batch_size, self.n_agents, -1).contiguous()
+        )
